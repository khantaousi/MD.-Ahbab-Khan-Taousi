{
  "entities": {
    "PortfolioData": {
      "title": "PortfolioData",
      "description": "The main data structure for the portfolio website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "currentWork": { "type": "string" },
        "profileImage": { "type": "string" },
        "logoUrl": { "type": "string" },
        "aboutText": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "theme": { "type": "string", "enum": ["neon", "gold", "rose", "emerald"] },
        "showAbout": { "type": "boolean" },
        "showSkills": { "type": "boolean" },
        "showBlog": { "type": "boolean" },
        "showGallery": { "type": "boolean" },
        "showContact": { "type": "boolean" },
        "showClock": { "type": "boolean" },
        "showNotice": { "type": "boolean" },
        "showWork": { "type": "boolean" },
        "showJobExperience": { "type": "boolean" },
        "showLiveChat": { "type": "boolean" },
        "showEventSection": { "type": "boolean" },
        "showSkillsChart": { "type": "boolean" },
        "socialLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "platform": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "image": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "image": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "proficiency": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        },
        "jobExperiences": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "companyName": { "type": "string" },
              "website": { "type": "string" },
              "logoUrl": { "type": "string" },
              "duration": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "notice": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "updatedAt": { "type": "string" }
          }
        },
        "seo": {
          "type": "object",
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "metaKeywords": { "type": "string" },
            "favicon": { "type": "string" }
          }
        }
      }
    }
  },
  "firestore": {
    "/portfolio/global": {
      "schema": { "$ref": "#/entities/PortfolioData" },
      "description": "Stores the basic portfolio settings and info."
    },
    "/portfolio/projects": {
      "schema": { "type": "object", "properties": { "projects": { "type": "array", "$ref": "#/entities/PortfolioData/properties/projects" } } },
      "description": "Stores the portfolio projects."
    },
    "/portfolio/gallery": {
      "schema": { "type": "object", "properties": { "gallery": { "type": "array", "$ref": "#/entities/PortfolioData/properties/gallery" } } },
      "description": "Stores the portfolio gallery items."
    },
    "/portfolio/jobExperiences": {
      "schema": { "type": "object", "properties": { "jobExperiences": { "type": "array", "$ref": "#/entities/PortfolioData/properties/jobExperiences" } } },
      "description": "Stores the job experiences."
    },
    "/chatMessages/{messageId}": {
      "schema": {
        "type": "object",
        "properties": {
          "sender": { "type": "string" },
          "text": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      },
      "description": "Stores live chat messages."
    },
    "/visits/{visitId}": {
      "schema": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "userAgent": { "type": "string" },
          "path": { "type": "string" }
        }
      },
      "description": "Stores visitor analytics data."
    }
  }
}
