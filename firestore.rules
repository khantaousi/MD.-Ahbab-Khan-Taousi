rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "khantaousi@gmail.com" && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // OTPs are private to the user
    match /otps/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Portfolio data is public read, authenticated write
    match /portfolio/{documentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Analytics/Visits data
    match /visits/{visitId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // WebRTC Signaling data for P2P file transfer
    match /transfers/{document=**} {
      allow read, write: if true;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
