{
  "entities": {
    "PortfolioData": {
      "title": "PortfolioData",
      "description": "The main data structure for the portfolio website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "currentWork": { "type": "string" },
        "profileImage": { "type": "string" },
        "aboutText": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "theme": { "type": "string", "enum": ["neon", "gold", "rose", "emerald"] },
        "showAbout": { "type": "boolean" },
        "showSkills": { "type": "boolean" },
        "showBlog": { "type": "boolean" },
        "showGallery": { "type": "boolean" },
        "showContact": { "type": "boolean" },
        "showClock": { "type": "boolean" },
        "showNotice": { "type": "boolean" },
        "showWork": { "type": "boolean" },
        "showProducts": { "type": "boolean" },
        "socialLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "platform": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "image": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "image": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "notice": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "updatedAt": { "type": "string" }
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "amount": { "type": "string" },
              "currency": { "type": "string" },
              "description": { "type": "string" },
              "images": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "orders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "productImage": { "type": "string" },
              "customerName": { "type": "string" },
              "customerContact": { "type": "string" },
              "customerCountry": { "type": "string" },
              "timestamp": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "processing", "shipped", "completed", "cancelled"] }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/portfolio/{documentId}": {
      "schema": { "$ref": "#/entities/PortfolioData" },
      "description": "Stores the global portfolio data."
    }
  }
}
